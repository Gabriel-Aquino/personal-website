---
const today = new Date();
import { resume } from "../data/resume";
---

<footer class="w-full border-t border-zinc-200 dark:border-brand-surface bg-white dark:bg-brand-bg py-8 mt-auto">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-8 text-center md:text-left">
    <div class="flex flex-col items-center md:items-start gap-4">
      <div class="text-sm text-zinc-500 dark:text-zinc-400">
        &copy; {today.getFullYear()} {resume.name}. Todos os direitos reservados.<br/>
        <span class="text-xs">Arquitetura sustentável, performance extrema e design limpo.</span>
      </div>
      <a 
        href="mailto:gabrielaquinocastelobranco@gmail.com" 
        class="inline-flex items-center gap-2 px-6 py-2.5 bg-brand-primary text-white text-sm font-bold rounded-full hover:bg-brand-accent transition-colors shadow-lg shadow-brand-primary/20 hover:scale-105 duration-300"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
        Fale Comigo
      </a>
    </div>
    
    <div class="flex flex-col items-center md:items-end gap-3">
      <div class="flex flex-wrap justify-center items-center gap-x-6 gap-y-2 text-sm font-medium text-zinc-600 dark:text-zinc-400">
        <a href="/" class="hover:text-brand-primary dark:hover:text-brand-accent transition-colors">Home</a>
        <a href="/portfolio" class="hover:text-brand-primary dark:hover:text-brand-accent transition-colors">Portfólio</a>
        <a href="/blog" class="hover:text-brand-primary dark:hover:text-brand-accent transition-colors">Blog</a>
      </div>
      <div class="flex items-center gap-4 text-sm font-medium text-zinc-500 dark:text-zinc-500">
        <a href={resume.socials.linkedin} target="_blank" class="hover:text-brand-primary dark:hover:text-brand-accent transition-colors">LinkedIn</a>
        <span>&bull;</span>
        <a href={resume.socials.github} target="_blank" class="hover:text-brand-primary dark:hover:text-brand-accent transition-colors">GitHub</a>
      </div>
    </div>
  </div>
</footer>
