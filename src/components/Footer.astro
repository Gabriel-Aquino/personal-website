---
const today = new Date();
import { resume } from "../data/resume";
---

<footer
  class="w-full border-t border-zinc-200 dark:border-brand-surface bg-white dark:bg-brand-bg py-8 mt-auto"
>
  <div
    class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-center sm:text-left"
  >
    <div class="text-sm text-zinc-500 dark:text-zinc-400">
      &copy; {today.getFullYear()}
      {" " + resume.name}. Todos os direitos reservados.
    </div>

    <div
      class="flex items-center gap-4 text-sm font-medium text-zinc-500 dark:text-zinc-500"
    >
      <a
        href={resume.socials.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-brand-primary dark:hover:text-brand-accent transition-colors"
      >
        LinkedIn
      </a>
      <span>&bull;</span>
      <a
        href={resume.socials.github}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-brand-primary dark:hover:text-brand-accent transition-colors"
      >
        GitHub
      </a>
    </div>
  </div>
</footer>
