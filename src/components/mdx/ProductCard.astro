---
interface Props {
  index?: number;
  title?: string;
  description?: string;
  imageUrl?: string;
  affiliateLink?: string;
  price?: string;
  badge?: string;
}

const { index } = Astro.props;

let affiliate: Partial<Props> | null = null;

// Try to find the product from the frontmatter array using index
if (!affiliate && typeof index === "number" && Astro.locals.affiliateProducts) {
  const frontmatterProduct = Astro.locals.affiliateProducts[index];
  if (frontmatterProduct) {
    affiliate = {
      ...frontmatterProduct,
      affiliateLink: frontmatterProduct.link, // map 'link' from frontmatter to 'affiliateLink'
    } as Partial<Props>;
  }
}

// Fallback to empty object if nothing is found
if (!affiliate) {
  affiliate = {};
}

// Merge props with JSON data, preferring explicitly passed props
const title = Astro.props.title || affiliate?.title || "Produto não encontrado";
const description = Astro.props.description || affiliate?.description || "";
const imageUrl = Astro.props.imageUrl || affiliate?.imageUrl || "";
const affiliateLink =
  Astro.props.affiliateLink || affiliate?.affiliateLink || "#";
const price = Astro.props.price || affiliate?.price;
const badge = Astro.props.badge || affiliate?.badge;
---

<div
  class="my-8 flex flex-col sm:flex-row bg-white dark:bg-brand-surface border border-zinc-200 dark:border-zinc-800 rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow group not-prose"
>
  <div
    class="sm:w-1/3 relative overflow-hidden bg-zinc-50 dark:bg-brand-bg flex items-center justify-center p-6"
  >
    {
      badge && (
        <span class="absolute top-3 left-3 bg-gradient-to-r from-brand-primary to-[#ff5b5b] text-white text-xs font-bold px-3 py-1 rounded-full z-10 shadow-sm uppercase tracking-wide">
          {badge}
        </span>
      )
    }
    <img
      src={imageUrl}
      alt={title}
      class="w-full h-auto max-h-48 object-contain group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
    />
  </div>
  <div class="p-6 sm:w-2/3 flex flex-col justify-between">
    <div>
      <h3 class="text-xl font-bold text-zinc-900 dark:text-brand-text mb-2">
        {title}
      </h3>
      <p class="text-zinc-600 dark:text-zinc-400 text-sm mb-6 leading-relaxed">
        {description}
      </p>
    </div>
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mt-auto pt-4 border-t border-zinc-100 dark:border-zinc-800/50">
      {
        price && (
          <span class="text-2xl font-extrabold text-zinc-900 dark:text-brand-text text-center sm:text-left">
            {price}
          </span>
        )
      }
      <a
        href={affiliateLink}
        target="_blank"
        rel="noopener noreferrer sponsored"
        class="inline-flex items-center justify-center bg-brand-primary hover:bg-[#ff5b5b] text-white font-bold py-3 sm:py-2.5 px-6 rounded-xl transition-colors shadow-lg shadow-brand-primary/20 w-full sm:w-auto sm:ml-auto"
      >
        Ver Oferta
      </a>
    </div>
  </div>
</div>
