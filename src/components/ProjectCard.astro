---
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"portfolio">;
}

const { project } = Astro.props;
---

<a
  href={`/portfolio/${project.id}`}
  class="group flex flex-col bg-white dark:bg-brand-surface border border-zinc-200 dark:border-zinc-800 rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
>
  {
    project.data.coverImage && (
      <div class="w-full aspect-video overflow-hidden border-b border-zinc-200 dark:border-zinc-800">
        <img
          src={project.data.coverImage.src}
          alt={project.data.projectName}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      </div>
    )
  }

  <div class="p-6 flex flex-col flex-grow">
    <h2
      class="text-2xl font-bold text-zinc-900 dark:text-brand-text mb-3 group-hover:text-brand-primary dark:group-hover:text-brand-accent transition-colors"
    >
      {project.data.projectName}
    </h2>
    {
      project.data.description && (
        <p class="text-zinc-600 dark:text-zinc-400 line-clamp-3 mb-4">
          {project.data.description}
        </p>
      )
    }
    <div class="flex flex-wrap gap-2 mt-auto">
      {
        project.data.techStack.map((tech) => (
          <span class="px-3 py-1 bg-brand-accent/10 text-brand-accent border border-brand-accent/20 rounded-full text-xs font-semibold uppercase tracking-wider">
            {tech}
          </span>
        ))
      }
    </div>
  </div>
</a>
