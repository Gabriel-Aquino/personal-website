<div
  class="giscus-container my-12 pt-8 border-t border-zinc-200 dark:border-zinc-800"
>
  <div class="giscus"></div>
</div>

<script>
  // Precisamos injetar o script do Giscus dinamicamente para suportar View Transitions
  function loadGiscus() {
    const container = document.querySelector(".giscus");
    if (!container) return;

    // Evita duplicar se já foi carregado
    if (container.innerHTML !== "") return;

    const script = document.createElement("script");
    script.src = "https://giscus.app/client.js";
    script.setAttribute("data-repo", "Gabriel-Aquino/personal-website");
    script.setAttribute("data-repo-id", "R_kgDOTDIXqg");

    script.setAttribute("data-category", "Q&A");
    script.setAttribute("data-category-id", "DIC_kwDOTDIXqs4C_v24");

    script.setAttribute("data-mapping", "title");
    script.setAttribute("data-strict", "0");
    script.setAttribute("data-reactions-enabled", "1");
    script.setAttribute("data-emit-metadata", "0");
    script.setAttribute("data-input-position", "bottom");

    // Define o tema inicial baseado na classe do HTML
    const isDark = document.documentElement.classList.contains("dark");
    script.setAttribute("data-theme", isDark ? "dark" : "light");

    script.setAttribute("data-lang", "pt");
    script.setAttribute("crossorigin", "anonymous");
    script.async = true;

    container.appendChild(script);
  }

  // Carrega na primeira vez
  loadGiscus();

  // Recarrega o Giscus toda vez que a View Transition navegar para uma nova página
  document.addEventListener("astro:page-load", loadGiscus);

  // Observer para escutar mudanças no tema e atualizar o Giscus sem recarregar a página
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.attributeName === "class") {
        const isDark = document.documentElement.classList.contains("dark");
        const theme = isDark ? "dark" : "light";
        const iframe = document.querySelector(
          "iframe.giscus-frame",
        ) as HTMLIFrameElement;

        if (iframe && iframe.contentWindow) {
          iframe.contentWindow.postMessage(
            { giscus: { setConfig: { theme } } },
            "https://giscus.app",
          );
        }
      }
    });
  });

  observer.observe(document.documentElement, { attributes: true });
</script>
