---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"a">;

const { href, class: className, ...props } = Astro.props;
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, "");
const subpath = pathname.match(/[^\/]+/g);
const isActive = href === pathname || href === "/" + (subpath?.[0] || "");
---

<a
  href={href}
  class:list={[
    className,
    "px-3 py-2 text-sm font-semibold transition-colors duration-200 relative group",
    isActive
      ? "text-brand-primary dark:text-brand-accent"
      : "text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-brand-text",
  ]}
  {...props}
>
  <slot />
  {
    isActive && (
      <span class="absolute inset-x-1 -bottom-[15px] h-0.5 bg-brand-primary dark:bg-brand-accent" />
    )
  }
</a>
