---
import BaseLayout from "../layouts/BaseLayout.astro";
import profileAvatar from "../assets/profile-avatar.webp";
import { resume } from "../data/resume";
---

<BaseLayout
  title="Gabriel Aquino | Hub Digital"
  description={resume.bio}
  image={profileAvatar}
>
  <!-- Hero Section -->
  <section
    class="flex flex-col-reverse md:flex-row items-center justify-between gap-12 py-16"
  >
    <div class="flex-1 space-y-8">
      <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight">
        Olá, eu sou <br />
        <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-brand-primary to-brand-accent"
        >
          {resume.name}
        </span> 👋
      </h1>
      <p class="text-2xl text-zinc-800 dark:text-brand-text font-semibold">
        {resume.role}
      </p>
      <p
        class="text-lg text-zinc-600 dark:text-zinc-400 leading-relaxed max-w-2xl"
      >
        {resume.bio}
      </p>

      <div class="flex flex-wrap gap-4 pt-4">
        <a
          href={resume.socials.github}
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-3.5 bg-zinc-900 text-zinc-50 dark:bg-brand-surface dark:text-brand-text dark:border dark:border-zinc-800 font-bold rounded-xl hover:scale-105 transition-transform duration-300 shadow-xl shadow-zinc-900/20 dark:shadow-none"
        >
          GitHub
        </a>
        <a
          href={resume.socials.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-3.5 bg-brand-primary text-white font-bold rounded-xl hover:scale-105 transition-transform duration-300 shadow-xl shadow-brand-primary/30"
        >
          LinkedIn
        </a>
      </div>
    </div>

    <!-- Hero Image with Glassmorphism / Glow -->
    <div class="w-64 h-64 md:w-96 md:h-96 relative group shrink-0">
      <div
        class="absolute inset-0 bg-gradient-to-tr from-brand-primary to-brand-accent rounded-full blur-3xl opacity-40 group-hover:opacity-70 transition-opacity duration-700"
      >
      </div>
      <img
        src="https://github.com/Gabriel-Aquino.png"
        alt={resume.name}
        class="relative w-full h-full object-cover rounded-full border-4 border-white dark:border-brand-bg shadow-2xl"
      />
    </div>
  </section>

  <!-- Skills (Extra Touch) -->
  <section
    class="py-10 border-y border-zinc-200 dark:border-brand-surface my-10 overflow-hidden"
  >
    <div class="flex flex-wrap gap-4 justify-center items-center">
      {
        resume.skills.map((skill) => (
          <span class="px-5 py-2 bg-zinc-100 dark:bg-brand-surface text-zinc-700 dark:text-brand-text rounded-full font-medium text-sm border border-zinc-200 dark:border-zinc-800 shadow-sm">
            {skill}
          </span>
        ))
      }
    </div>
  </section>

  <!-- Timeline Experiência Profissional -->
  <section>
    <div class="flex items-center gap-4 mb-12">
      <h2 class="text-3xl font-bold w-full text-center">
        Experiência Profissional
      </h2>
    </div>

    <div
      class="space-y-10 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-brand-primary/50 before:via-zinc-300 dark:before:via-brand-surface before:to-transparent"
    >
      {
        resume.experience.map((exp) => (
          <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group">
            {/* Ícone Timeline */}
            <div class="flex items-center justify-center w-10 h-10 rounded-full border-4 border-white dark:border-brand-bg bg-gradient-to-br from-brand-primary to-brand-accent text-white shadow-lg shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 z-10 relative">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z"
                  clip-rule="evenodd"
                />
              </svg>
            </div>

            {/* Card Conteúdo */}
            <div class="w-[calc(100%-4rem)] md:w-[calc(50%-3rem)] bg-white dark:bg-brand-surface p-8 rounded-3xl shadow-xl shadow-zinc-200/20 dark:shadow-none border border-zinc-100 dark:border-zinc-800/80 hover:-translate-y-1.5 transition-all duration-300 hover:shadow-brand-primary/10 dark:hover:shadow-brand-accent/10 backdrop-blur-sm">
              <div class="flex flex-col xl:flex-row xl:items-center justify-between mb-4 gap-2">
                <h3 class="text-2xl font-bold text-zinc-900 dark:text-brand-text">
                  {exp.role}
                </h3>
                <span class="text-sm text-brand-accent font-bold bg-brand-accent/10 px-4 py-1.5 rounded-full border border-brand-accent/20 shrink-0">
                  {exp.period}
                </span>
              </div>
              <h4 class="text-lg font-semibold text-brand-primary mb-4">
                {exp.company}
              </h4>
              <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed text-base">
                {exp.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
