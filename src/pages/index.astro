---
import BaseLayout from "../layouts/BaseLayout.astro";
import { BlogService } from "../services/BlogService";
import { PortfolioService } from "../services/PortfolioService";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { Image } from "astro:assets";
import PostCard from "../components/PostCard.astro";

const posts = await BlogService.getAllPosts();
const tags = await BlogService.getAllTags();
const featuredPosts = await BlogService.getFeaturedPosts();
const featuredProjects = await PortfolioService.getFeaturedProjects();
const categories = await BlogService.getAllCategories();
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <div class="max-w-7xl px-4 lg:px-8 mx-auto py-8 md:py-12">
    <!-- Minimalist Intro -->
    <header class="mb-16 space-y-4 max-w-3xl">
      <h1
        class="text-2xl md:text-3xl font-extrabold tracking-tight text-zinc-900 dark:text-zinc-100"
      >
        Olá! Eu sou o Gabriel Aquino
      </h1>
      <p
        class="text-lg md:text-xl text-zinc-600 dark:text-zinc-400 leading-relaxed"
      >
        Engenheiro de Software focado em arquiteturas escaláveis. 🚀 <br /> Fique à vontade para explorar meus artigos e projetos!
      </p>
    </header>

    <section>
      <!-- Featured Section -->
      {
        (featuredPosts.length > 0 || featuredProjects.length > 0) && (
          <div class="mb-16">
            <h2 class="text-2xl font-extrabold tracking-tight text-zinc-900 dark:text-zinc-100 mb-6 border-b border-zinc-200 dark:border-zinc-800 pb-4 flex items-center gap-2">
              <svg
                class="w-6 h-6 text-brand-primary"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
              </svg>
              Destaques
            </h2>

            {featuredProjects.length > 0 && (
              <div class="mb-10">
                <h3 class="text-lg font-bold text-zinc-700 dark:text-zinc-300 mb-4">
                  Projetos em Destaque
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                  {featuredProjects.map((project) => (
                    <article class="group relative flex flex-col justify-between p-5 rounded-2xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-brand-surface shadow-sm hover:shadow-md transition-shadow h-full">
                      <div class="flex-1 flex flex-col">
                        {project.data.coverImage && (
                          <div class="aspect-video w-full mb-4 overflow-hidden rounded-xl bg-zinc-100 dark:bg-zinc-800">
                            {typeof project.data.coverImage === "string" ? (
                              <img
                                src={project.data.coverImage}
                                alt={project.data.projectName}
                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                loading="lazy"
                              />
                            ) : (
                              <Image
                                src={project.data.coverImage}
                                alt={project.data.projectName}
                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                              />
                            )}
                          </div>
                        )}

                        <h3 class="text-base font-bold text-zinc-900 dark:text-zinc-100 group-hover:text-brand-primary transition-colors line-clamp-2">
                          <a href={`/portfolio/${project.id}`}>
                            <span class="absolute inset-0 z-20" />
                            {project.data.projectName}
                          </a>
                        </h3>
                      </div>
                      <div class="mt-4 flex items-center text-xs font-bold text-brand-primary group-hover:text-brand-accent transition-colors">
                        Ver projeto
                        <svg
                          class="w-3 h-3 ml-1 group-hover:translate-x-1 transition-transform"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M9 5l7 7-7 7"
                          />
                        </svg>
                      </div>
                    </article>
                  ))}
                </div>
              </div>
            )}

            {featuredPosts.length > 0 && (
              <div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                  {featuredPosts.map((post) => (
                    <PostCard post={post} />
                  ))}
                </div>
              </div>
            )}
          </div>
        )
      }

      <!-- Categories Tabs (Filters) -->
      <div class="mb-8">
        <div
          class="flex gap-4 overflow-x-auto pb-4 custom-scrollbar border-b border-zinc-200 dark:border-zinc-800"
        >
          <button
            data-category="all"
            class="category-btn pb-3 border-b-2 font-bold whitespace-nowrap px-2 transition-colors text-brand-primary border-brand-primary"
          >
            Todos
          </button>
          {
            categories.map((cat) => (
              <button
                data-category={cat}
                class="category-btn pb-3 border-b-2 font-bold whitespace-nowrap px-2 transition-colors border-transparent text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 hover:border-zinc-300 dark:hover:border-zinc-700"
              >
                {cat}
              </button>
            ))
          }
        </div>
      </div>

      <!-- Tags Filter -->
      <div class="mb-12">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-4">
          <h3
            class="text-sm font-bold text-zinc-500 dark:text-zinc-400 uppercase tracking-wider"
          >
            Filtrar por Assunto
          </h3>
          <div class="relative w-full sm:w-64">
            <input
              type="text"
              id="tag-search"
              placeholder="Pesquisar tag..."
              class="w-full text-xs px-3 py-1.5 pl-8 rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-brand-surface text-zinc-800 dark:text-zinc-200 placeholder-zinc-400 dark:placeholder-zinc-500 focus:outline-none focus:ring-1 focus:ring-brand-primary focus:border-brand-primary transition-all"
            />
            <svg
              class="absolute left-2.5 top-2.5 w-3.5 h-3.5 text-zinc-400 dark:text-zinc-500"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
              />
            </svg>
          </div>
        </div>
        <div
          class="flex flex-nowrap gap-2 overflow-x-auto pb-4 custom-scrollbar"
        >
          <button
            data-tag="all"
            class="tag-btn uppercase tracking-wider text-[10px] font-bold text-brand-primary px-3 py-1.5 bg-brand-primary/10 border border-brand-primary/20 rounded-full transition-all shadow-sm shrink-0"
          >
            Todos
          </button>
          {
            tags.map((tag) => (
              <button
                data-tag={tag}
                class="tag-btn uppercase tracking-wider text-[10px] font-bold text-zinc-600 dark:text-zinc-400 px-3 py-1.5 bg-zinc-100 dark:bg-zinc-800/50 border border-zinc-200 dark:border-zinc-700/50 rounded-full hover:bg-brand-primary hover:text-white dark:hover:bg-brand-primary dark:hover:text-white hover:border-brand-primary dark:hover:border-brand-primary transition-all shadow-sm shrink-0"
              >
                {tag}
              </button>
            ))
          }
        </div>
      </div>

      <!-- All Posts Section -->
      <h2
        class="text-2xl font-extrabold tracking-tight text-zinc-900 dark:text-zinc-100 mb-6 border-b border-zinc-200 dark:border-zinc-800 pb-4"
      >
        Últimas postagens
      </h2>

      <div
        id="posts-container"
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"
      >
        {
          posts.map((post, index) => {
            const isHero = index === 0;
            return (
              <PostCard post={post} isHero={isHero} withDataAttributes={true} />
            );
          })
        }
      </div>

      {
        posts.length === 0 && (
          <p class="text-zinc-500 dark:text-zinc-400 italic mt-8">
            Nenhuma postagem publicada ainda.
          </p>
        )
      }

      <p
        id="empty-state"
        class="hidden text-zinc-500 dark:text-zinc-400 italic mt-8"
      >
        Nenhuma postagem encontrada para este filtro.
      </p>
    </section>
  </div>
</BaseLayout>

<script>
  const initFilters = () => {
    const categoryBtns = document.querySelectorAll(".category-btn");
    const tagBtns = document.querySelectorAll(".tag-btn");
    const postCards = document.querySelectorAll("#posts-container .post-card");
    const emptyState = document.getElementById("empty-state");
    const tagSearch = document.getElementById("tag-search") as HTMLInputElement | null;

    let activeCategory = "all";
    let activeTag = "all";
    let tagSearchQuery = "";

    function updatePosts() {
      let firstVisibleFound = false;
      let visibleCount = 0;

      postCards.forEach((card) => {
        const cat = card.getAttribute("data-category");
        const tags = card.getAttribute("data-tags")?.split(",") || [];

        const matchCategory =
          activeCategory === "all" || cat === activeCategory;
        const matchTag = activeTag === "all" || tags.includes(activeTag);

        if (matchCategory && matchTag) {
          (card as HTMLElement).style.display = "flex";
          visibleCount++;

          // Apply hero styles to the first visible post
          if (!firstVisibleFound) {
            card.classList.add("md:col-span-2", "lg:col-span-3");
            card
              .querySelector(".img-container")
              ?.classList.add("lg:aspect-[21/7]");
            const title = card.querySelector(".post-title");
            title?.classList.add("text-2xl", "md:text-4xl");
            title?.classList.remove("text-xl");
            const desc = card.querySelector(".post-desc");
            desc?.classList.add("text-base", "md:text-lg");
            desc?.classList.remove("text-sm");
            firstVisibleFound = true;
          } else {
            // Remove hero styles for subsequent visible posts
            card.classList.remove("md:col-span-2", "lg:col-span-3");
            card
              .querySelector(".img-container")
              ?.classList.remove("lg:aspect-[21/7]");
            const title = card.querySelector(".post-title");
            title?.classList.remove("text-2xl", "md:text-4xl");
            title?.classList.add("text-xl");
            const desc = card.querySelector(".post-desc");
            desc?.classList.remove("text-base", "md:text-lg");
            desc?.classList.add("text-sm");
          }
        } else {
          (card as HTMLElement).style.display = "none";
          card.classList.remove("md:col-span-2", "lg:col-span-3");
        }
      });

      if (emptyState) {
        if (visibleCount === 0) {
          emptyState.classList.remove("hidden");
        } else {
          emptyState.classList.add("hidden");
        }
      }
    }

    function updateTags() {
      // Dynamic cascading: find all tags belonging to posts in the active category
      const allowedTags = new Set<string>();
      postCards.forEach((card) => {
        const cat = card.getAttribute("data-category");
        if (activeCategory === "all" || cat === activeCategory) {
          const cardTags = card.getAttribute("data-tags")?.split(",") || [];
          cardTags.forEach((t) => {
            if (t) allowedTags.add(t.toLowerCase().trim());
          });
        }
      });

      let activeTagStillVisible = activeTag === "all";

      tagBtns.forEach((btn) => {
        const tag = btn.getAttribute("data-tag");
        if (!tag || tag === "all") return;

        const tagClean = tag.toLowerCase().trim();
        const matchesCategory = allowedTags.has(tagClean);
        const matchesSearch = tagClean.includes(tagSearchQuery);

        if (matchesCategory && matchesSearch) {
          (btn as HTMLElement).style.display = "inline-flex";
          if (activeTag === tag) {
            activeTagStillVisible = true;
          }
        } else {
          (btn as HTMLElement).style.display = "none";
        }
      });

      // If active tag was filtered out, reset active tag to "all"
      if (!activeTagStillVisible) {
        activeTag = "all";
        tagBtns.forEach((b) => {
          const t = b.getAttribute("data-tag");
          if (t === "all") {
            b.classList.add(
              "text-brand-primary",
              "bg-brand-primary/10",
              "border-brand-primary/20",
            );
            b.classList.remove(
              "bg-zinc-100",
              "dark:bg-zinc-800/50",
              "text-zinc-600",
              "dark:text-zinc-400",
              "border-zinc-200",
              "dark:border-zinc-700/50",
            );
          } else {
            b.classList.remove(
              "text-brand-primary",
              "bg-brand-primary/10",
              "border-brand-primary/20",
            );
            b.classList.add(
              "bg-zinc-100",
              "dark:bg-zinc-800/50",
              "text-zinc-600",
              "dark:text-zinc-400",
              "border-zinc-200",
              "dark:border-zinc-700/50",
            );
          }
        });
        updatePosts();
      }
    }

    if (tagSearch) {
      tagSearch.addEventListener("input", (e) => {
        tagSearchQuery = (e.target as HTMLInputElement).value.toLowerCase().trim();
        updateTags();
      });
    }

    categoryBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        activeCategory = btn.getAttribute("data-category") || "all";

        // Update button styles
        categoryBtns.forEach((b) => {
          b.classList.remove("text-brand-primary", "border-brand-primary");
          b.classList.add(
            "border-transparent",
            "text-zinc-500",
            "dark:text-zinc-400",
            "hover:text-zinc-900",
            "dark:hover:text-zinc-100",
            "hover:border-zinc-300",
            "dark:hover:border-zinc-700"
          );
        });
        btn.classList.add("text-brand-primary", "border-brand-primary");
        btn.classList.remove(
          "border-transparent",
          "text-zinc-500",
          "dark:text-zinc-400",
          "hover:text-zinc-900",
          "dark:hover:text-zinc-100",
          "hover:border-zinc-300",
          "dark:hover:border-zinc-700"
        );

        // Reset tag search on category change for better UX
        if (tagSearch) {
          tagSearch.value = "";
          tagSearchQuery = "";
        }

        updateTags();
        updatePosts();
      });
    });

    tagBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        activeTag = btn.getAttribute("data-tag") || "all";

        // Update button styles
        tagBtns.forEach((b) => {
          b.classList.remove(
            "text-brand-primary",
            "bg-brand-primary/10",
            "border-brand-primary/20",
          );
          b.classList.add(
            "bg-zinc-100",
            "dark:bg-zinc-800/50",
            "text-zinc-600",
            "dark:text-zinc-400",
            "border-zinc-200",
            "dark:border-zinc-700/50",
          );
        });
        btn.classList.add(
          "text-brand-primary",
          "bg-brand-primary/10",
          "border-brand-primary/20",
        );
        btn.classList.remove(
          "bg-zinc-100",
          "dark:bg-zinc-800/50",
          "text-zinc-600",
          "dark:text-zinc-400",
          "border-zinc-200",
          "dark:border-zinc-700/50",
        );

        updatePosts();
      });
    });

    // Initial setup
    updateTags();
    updatePosts();
  };

  document.addEventListener("astro:page-load", () => {
    if (document.getElementById("posts-container")) {
      initFilters();
    }
  });
</script>

<style>
  .custom-scrollbar::-webkit-scrollbar {
    height: 6px;
    width: 6px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background-color: #d4d4d8;
    border-radius: 10px;
  }
  :global(.dark) .custom-scrollbar::-webkit-scrollbar-thumb {
    background-color: #3f3f46;
  }
</style>
