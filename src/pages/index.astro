---
import BaseLayout from "../layouts/BaseLayout.astro";
import { resume } from "../data/resume";
---

<BaseLayout title="Gabriel Aquino | Hub Digital" description={resume.bio}>
  <!-- Hero Section -->
  <section
    class="flex flex-col md:flex-row items-center justify-between gap-6 md:gap-12 py-4 md:py-10"
  >
    <div class="flex-1 w-full space-y-4 md:space-y-8 min-w-0">
      <!-- Wrapper for Mobile: Title + Image Side by Side -->
      <div class="flex flex-row justify-between items-center gap-4 w-full">
        <h1
          class="text-3xl sm:text-4xl md:text-6xl font-extrabold tracking-tight break-words flex-1"
        >
          Olá, eu sou <br class="hidden md:block" />
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-brand-primary to-brand-accent block mt-1 md:inline md:mt-0"
          >
            {resume.name}
          </span> 👋
        </h1>

        <!-- Mobile Image -->
        <div
          class="w-24 h-24 sm:w-32 sm:h-32 relative group shrink-0 md:hidden"
        >
          <div
            class="absolute inset-0 bg-gradient-to-tr from-brand-primary to-brand-accent rounded-full blur-xl opacity-40 group-hover:opacity-70 transition-opacity duration-700"
          >
          </div>
          <img
            src="https://github.com/Gabriel-Aquino.png"
            alt={resume.name}
            class="relative w-full h-full object-cover rounded-full border-2 border-white dark:border-brand-bg shadow-xl"
          />
        </div>
      </div>

      <!-- Role, Bio and Buttons -->
      <div class="space-y-4 md:space-y-8">
        <p
          class="text-base sm:text-lg md:text-2xl text-zinc-800 dark:text-brand-text font-semibold"
        >
          {resume.role}
        </p>
        <p
          class="text-sm sm:text-base md:text-lg text-zinc-600 dark:text-zinc-400 leading-relaxed md:max-w-2xl"
        >
          {resume.bio}
        </p>

        <div class="flex flex-wrap gap-3 md:gap-4 pt-2 md:pt-4">
          <a
            href={resume.socials.github}
            target="_blank"
            rel="noopener noreferrer"
            class="flex-1 md:flex-none px-4 md:px-8 py-2.5 md:py-3.5 bg-zinc-900 text-zinc-50 dark:bg-brand-surface dark:text-brand-text dark:border dark:border-zinc-800 font-bold rounded-xl text-sm md:text-base text-center hover:scale-105 transition-transform duration-300 shadow-xl shadow-zinc-900/20 dark:shadow-none"
          >
            GitHub
          </a>
          <a
            href={resume.socials.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="flex-1 md:flex-none px-4 md:px-8 py-2.5 md:py-3.5 bg-brand-primary text-white font-bold rounded-xl text-sm md:text-base text-center hover:scale-105 transition-transform duration-300 shadow-xl shadow-brand-primary/30"
          >
            LinkedIn
          </a>
        </div>
      </div>
    </div>

    <!-- Desktop Image -->
    <div class="hidden md:block w-96 h-96 relative group shrink-0">
      <div
        class="absolute inset-0 bg-gradient-to-tr from-brand-primary to-brand-accent rounded-full blur-3xl opacity-40 group-hover:opacity-70 transition-opacity duration-700"
      >
      </div>
      <img
        src="https://github.com/Gabriel-Aquino.png"
        alt={resume.name}
        class="relative w-full h-full object-cover rounded-full border-4 border-white dark:border-brand-bg shadow-2xl"
      />
    </div>
  </section>

  <section
    class="py-14 border-y border-zinc-200 dark:border-brand-surface my-10 relative overflow-hidden"
  >
    <!-- Background Glow -->
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-3/4 h-3/4 bg-brand-primary/5 dark:bg-brand-primary/10 blur-[100px] rounded-full pointer-events-none"
    >
    </div>

    <div class="max-w-4xl mx-auto px-4">
      <h2
        class="text-3xl font-bold w-full text-center mb-10 text-zinc-900 dark:text-brand-text"
      >
        Tecnologias e Ferramentas
      </h2>
      <div
        class="relative flex overflow-hidden w-full group mask-image-fade py-4 z-10"
      >
        <div
          class="flex animate-marquee hover:[animation-play-state:paused] whitespace-nowrap min-w-max"
        >
          {
            [...resume.skills, ...resume.skills].map((skill) => (
              <div class="flex items-center gap-3 px-6 py-3.5 mx-2 bg-white dark:bg-brand-surface text-zinc-700 dark:text-brand-text rounded-2xl font-semibold text-sm border border-zinc-200 dark:border-zinc-800 shadow-sm hover:-translate-y-1 hover:shadow-brand-primary/20 dark:hover:border-brand-primary/50 transition-all duration-300">
                {skill.icon && (
                  <img
                    src={skill.icon}
                    alt={skill.name}
                    class="w-6 h-6 object-contain"
                  />
                )}
                <span>{skill.name}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Resumo Profissional -->
  <section class="mb-16">
    <div class="flex items-center gap-4 mb-12">
      <h2 class="text-3xl font-bold w-full text-center">Resumo Profissional</h2>
    </div>

    <div
      class="bg-white dark:bg-brand-surface p-8 md:p-10 rounded-3xl shadow-xl shadow-zinc-200/20 dark:shadow-none border border-zinc-100 dark:border-zinc-800/80 w-full mx-auto backdrop-blur-sm hover:-translate-y-1 transition-all duration-300 hover:shadow-brand-primary/5 dark:hover:shadow-brand-accent/5"
    >
      <p class="text-lg leading-relaxed text-zinc-600 dark:text-zinc-400 mb-8">
        Engenheiro de Software com um histórico comprovado na construção,
        sustentação e escala de plataformas B2B e B2C de alta disponibilidade.
        Com sólida experiência no ecossistema <strong
          class="text-brand-primary font-semibold">Node.js (TypeScript)</strong
        >, <strong class="text-brand-primary font-semibold"
          >Java (Spring Boot)</strong
        > e <strong class="text-brand-primary font-semibold">Go</strong>, atuo
        muito além da entrega de código, focando em estabilidade arquitetural,
        eficiência operacional e redução de custos de infraestrutura.
      </p>

      <h3 class="text-xl font-bold text-zinc-900 dark:text-brand-text mb-6">
        Destaques e Impacto
      </h3>
      <ul class="space-y-5 text-zinc-600 dark:text-zinc-400">
        <li
          class="relative pl-6 before:content-[''] before:absolute before:left-0 before:top-2 before:w-2 before:h-2 before:bg-brand-accent before:rounded-full"
        >
          <strong class="text-zinc-800 dark:text-zinc-300"
            >Engenharia e Arquitetura:</strong
          > Especialista na concepção de sistemas resilientes, atuando com Clean Architecture,
          SOLID e DDD (Domain-Driven Design). Experiência profunda em SaaS com arquiteturas
          multi-tenant (isolamento de dados) e integração de sistemas legados complexos.
        </li>
        <li
          class="relative pl-6 before:content-[''] before:absolute before:left-0 before:top-2 before:w-2 before:h-2 before:bg-brand-accent before:rounded-full"
        >
          <strong class="text-zinc-800 dark:text-zinc-300"
            >Cloud e Escalabilidade:</strong
          > Domínio na orquestração de microsserviços e fluxos assíncronos na AWS
          (SQS, SNS, Lambda, S3, EC2), garantindo tolerância a falhas em sistemas
          educacionais, financeiros e de saúde.
        </li>
        <li
          class="relative pl-6 before:content-[''] before:absolute before:left-0 before:top-2 before:w-2 before:h-2 before:bg-brand-accent before:rounded-full"
        >
          <strong class="text-zinc-800 dark:text-zinc-300"
            >Eficiência e Visão de Negócios:</strong
          > Histórico de automação de processos operacionais pesados (n8n, motores
          de OCR), uso estratégico de IA (LLMs/Cursor) para produtividade técnica
          de times e experiência direta no fechamento e expansão de contratos corporativos
          B2B.
        </li>
        <li
          class="relative pl-6 before:content-[''] before:absolute before:left-0 before:top-2 before:w-2 before:h-2 before:bg-brand-accent before:rounded-full"
        >
          <strong class="text-zinc-800 dark:text-zinc-300"
            >Qualidade e DevOps:</strong
          > Forte cultura de engenharia de software com automação de testes End-to-End
          (E2E) via Playwright e implementação de conteinerização (Docker) em ambientes
          de desenvolvimento.
        </li>
      </ul>

      <div
        class="mt-10 p-6 md:p-8 bg-zinc-50 dark:bg-brand-bg/50 rounded-2xl border border-zinc-200 dark:border-zinc-800/50 flex flex-col gap-4 text-zinc-700 dark:text-zinc-300"
      >
        <div class="flex items-start gap-3">
          <span class="text-xl shrink-0">🎓</span>
          <p>
            Formado em <strong class="text-brand-primary"
              >Sistemas de Informação</strong
            > pela FACIMP | Wyden e certificado pela Full Cycle em Fundamentos de
            Arquitetura, DDD e Comunicação entre Sistemas.
          </p>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-xl shrink-0">🗣️</span>
          <p>
            <strong class="text-brand-primary"
              >Inglês Intermediário/Avançado</strong
            > focado em comunicação técnica profissional.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline Experiência Profissional -->
  <section>
    <div class="flex items-center gap-4 mb-12">
      <h2 class="text-3xl font-bold w-full text-center">
        Experiência Profissional
      </h2>
    </div>

    <div
      class="space-y-10 relative before:absolute before:inset-0 before:ml-5 md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-brand-primary/50 before:via-zinc-300 dark:before:via-brand-surface before:to-transparent"
    >
      {
        resume.experience.slice(0, 2).map((exp, index) => (
          <div class="relative flex items-center md:justify-between w-full group/card">
            <div class="absolute top-8 left-5 md:left-1/2 -translate-x-1/2 flex items-center justify-center w-10 h-10 rounded-full border-4 border-white dark:border-brand-bg bg-gradient-to-br from-brand-primary to-brand-accent text-white shadow-lg z-10 group-hover/card:scale-110 transition-transform duration-300">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z"
                  clip-rule="evenodd"
                />
              </svg>
            </div>
            <div
              class={`hidden md:block w-[calc(50%-3rem)] ${index % 2 === 0 ? "order-2" : "order-1"}`}
            />
            <div
              class={`w-full ml-16 md:ml-0 md:w-[calc(50%-3rem)] bg-white dark:bg-brand-surface p-8 rounded-3xl shadow-xl shadow-zinc-200/20 dark:shadow-none border border-zinc-100 dark:border-zinc-800/80 hover:-translate-y-1.5 transition-all duration-300 hover:shadow-brand-primary/10 dark:hover:shadow-brand-accent/10 backdrop-blur-sm ${index % 2 === 0 ? "order-1" : "order-2"}`}
            >
              <div class="flex flex-col xl:flex-row xl:items-center justify-between mb-4 gap-2">
                <h3 class="text-2xl font-bold text-zinc-900 dark:text-brand-text">
                  {exp.role}
                </h3>
                <span class="text-sm text-brand-accent font-bold bg-brand-accent/10 px-4 py-1.5 rounded-full border border-brand-accent/20 shrink-0">
                  {exp.period}
                </span>
              </div>
              <h4 class="text-lg font-semibold text-brand-primary mb-4 flex items-center gap-2">
                {exp.company}
                {exp.location && (
                  <>
                    <span class="text-zinc-300 dark:text-zinc-700">|</span>
                    <span class="text-zinc-500 dark:text-zinc-400 text-sm font-normal">
                      {exp.location}
                    </span>
                  </>
                )}
              </h4>
              <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed text-base">
                {exp.description}
              </p>
              {exp.details && exp.details.length > 0 && (
                <details class="group/details mt-4">
                  <summary class="cursor-pointer text-sm font-bold text-brand-accent hover:text-brand-primary transition-colors flex items-center gap-1 select-none w-fit">
                    <span class="group-open/details:hidden">
                      Ver Detalhes ↓
                    </span>
                    <span class="hidden group-open/details:inline">
                      Ocultar Detalhes ↑
                    </span>
                  </summary>
                  <ul class="mt-4 space-y-3 text-sm text-zinc-600 dark:text-zinc-400 border-l-2 border-zinc-200 dark:border-zinc-800 pl-4">
                    {exp.details.map((detail: string) => (
                      <li class="relative before:content-[''] before:absolute before:-left-[21px] before:top-2 before:w-2 before:h-2 before:bg-brand-primary before:rounded-full">
                        {detail}
                      </li>
                    ))}
                  </ul>
                </details>
              )}
              {exp.techStack && exp.techStack.length > 0 && (
                <div class="mt-6 flex flex-wrap gap-2">
                  {exp.techStack.map((tech: string) => (
                    <span class="px-3 py-1 bg-brand-accent/5 text-brand-accent border border-brand-accent/10 rounded-full text-xs font-semibold uppercase tracking-wider">
                      {tech}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))
      }

      {
        resume.experience.length > 2 && (
          <details class="group/older mt-10">
            <summary class="w-full flex justify-center py-6 relative z-20 cursor-pointer list-none [&::-webkit-details-marker]:hidden outline-none">
              <div class="bg-white dark:bg-brand-surface border-2 border-brand-accent/20 dark:border-zinc-800 text-brand-primary dark:text-brand-text font-bold px-8 py-3.5 rounded-full hover:bg-brand-accent/5 transition-all shadow-lg hover:shadow-brand-accent/20 flex items-center gap-2">
                <span class="group-open/older:hidden">
                  Mostrar experiências anteriores ↓
                </span>
                <span class="hidden group-open/older:inline">
                  Ocultar experiências anteriores ↑
                </span>
              </div>
            </summary>
            <div class="space-y-10 mt-6 relative">
              {resume.experience.slice(2).map((exp, idx) => {
                const index = idx + 2;
                return (
                  <div class="relative flex items-center md:justify-between w-full group/card">
                    <div class="absolute top-8 left-5 md:left-1/2 -translate-x-1/2 flex items-center justify-center w-10 h-10 rounded-full border-4 border-white dark:border-brand-bg bg-gradient-to-br from-brand-primary to-brand-accent text-white shadow-lg z-10 group-hover/card:scale-110 transition-transform duration-300">
                      <svg
                        class="w-4 h-4"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                      >
                        <path
                          fill-rule="evenodd"
                          d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z"
                          clip-rule="evenodd"
                        />
                      </svg>
                    </div>
                    <div
                      class={`hidden md:block w-[calc(50%-3rem)] ${index % 2 === 0 ? "order-2" : "order-1"}`}
                    />
                    <div
                      class={`w-full ml-16 md:ml-0 md:w-[calc(50%-3rem)] bg-white dark:bg-brand-surface p-8 rounded-3xl shadow-xl shadow-zinc-200/20 dark:shadow-none border border-zinc-100 dark:border-zinc-800/80 hover:-translate-y-1.5 transition-all duration-300 hover:shadow-brand-primary/10 dark:hover:shadow-brand-accent/10 backdrop-blur-sm ${index % 2 === 0 ? "order-1" : "order-2"}`}
                    >
                      <div class="flex flex-col xl:flex-row xl:items-center justify-between mb-4 gap-2">
                        <h3 class="text-2xl font-bold text-zinc-900 dark:text-brand-text">
                          {exp.role}
                        </h3>
                        <span class="text-sm text-brand-accent font-bold bg-brand-accent/10 px-4 py-1.5 rounded-full border border-brand-accent/20 shrink-0">
                          {exp.period}
                        </span>
                      </div>
                      <h4 class="text-lg font-semibold text-brand-primary mb-4 flex items-center gap-2">
                        {exp.company}
                        {exp.location && (
                          <>
                            <span class="text-zinc-300 dark:text-zinc-700">
                              |
                            </span>
                            <span class="text-zinc-500 dark:text-zinc-400 text-sm font-normal">
                              {exp.location}
                            </span>
                          </>
                        )}
                      </h4>
                      <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed text-base">
                        {exp.description}
                      </p>
                      {exp.details && exp.details.length > 0 && (
                        <details class="group/details mt-4">
                          <summary class="cursor-pointer text-sm font-bold text-brand-accent hover:text-brand-primary transition-colors flex items-center gap-1 select-none w-fit">
                            <span class="group-open/details:hidden">
                              Ver Detalhes ↓
                            </span>
                            <span class="hidden group-open/details:inline">
                              Ocultar Detalhes ↑
                            </span>
                          </summary>
                          <ul class="mt-4 space-y-3 text-sm text-zinc-600 dark:text-zinc-400 border-l-2 border-zinc-200 dark:border-zinc-800 pl-4">
                            {exp.details.map((detail: string) => (
                              <li class="relative before:content-[''] before:absolute before:-left-[21px] before:top-2 before:w-2 before:h-2 before:bg-brand-primary before:rounded-full">
                                {detail}
                              </li>
                            ))}
                          </ul>
                        </details>
                      )}
                      {exp.techStack && exp.techStack.length > 0 && (
                        <div class="mt-6 flex flex-wrap gap-2">
                          {exp.techStack.map((tech: string) => (
                            <span class="px-3 py-1 bg-brand-accent/5 text-brand-accent border border-brand-accent/10 rounded-full text-xs font-semibold uppercase tracking-wider">
                              {tech}
                            </span>
                          ))}
                        </div>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
          </details>
        )
      }
    </div>
  </section>
</BaseLayout>
