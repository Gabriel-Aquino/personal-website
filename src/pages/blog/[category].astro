---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/BlogCard.astro";
import { BlogService } from "../../services/BlogService";
import { slugifyCategory } from "../../utils/url";

export async function getStaticPaths() {
  const categories = await BlogService.getAllCategories();

  return Promise.all(categories.map(async (category) => {
    const posts = await BlogService.getPostsByCategory(category);
    return {
      params: { category: slugifyCategory(category) },
      props: { category, posts },
    };
  }));
}

const { category, posts } = Astro.props;
---

<BaseLayout
  title={`${category} | Hub Digital`}
  description={`Artigos e conteúdos sobre ${category}.`}
>
  <div class="pb-12">
    <div class="mb-12">
      <a
        href="/blog"
        class="inline-block mb-6 text-sm font-bold text-zinc-500 hover:text-brand-primary transition-colors"
        >← Voltar</a
      >

      <h1
        class="text-5xl md:text-7xl font-extrabold tracking-tight mb-4 text-zinc-900 dark:text-brand-text leading-tight"
      >
        <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-brand-primary to-brand-accent"
          >{category}</span
        >
      </h1>
      <p class="text-xl text-zinc-600 dark:text-zinc-400 max-w-2xl">
        Explorando conteúdos profundos e isolados sobre {category}.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        posts.map((post) => <BlogCard post={post} />)
      }
    </div>
  </div>
</BaseLayout>
