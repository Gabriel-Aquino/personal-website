---
import { render } from "astro:content";
import BlogPost from "../../../layouts/BlogPost.astro";
import { BlogService } from "../../../services/BlogService";
import { slugifyCategory } from "../../../utils/url";
import type { CollectionEntry } from "astro:content";
import ProductCard from "../../../components/mdx/ProductCard.astro";

export async function getStaticPaths() {
  const posts = await BlogService.getAllPosts();
  return posts.map((post) => ({
    params: {
      category: slugifyCategory(post.data.category || "Geral"),
      slug: post.id,
    },
    props: post,
  }));
}
type Props = CollectionEntry<"blog">;

const post = Astro.props;
Astro.locals.affiliateProducts = post.data.affiliateProducts;

const { Content } = await render(post);
---

<BlogPost {...post.data}>
  <Content components={{ ProductCard }} />
</BlogPost>
