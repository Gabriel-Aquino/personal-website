---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/BlogCard.astro";
import { BlogService } from "../../services/BlogService";
import { slugifyCategory } from "../../utils/url";

const posts = await BlogService.getAllPosts();
const categories = await BlogService.getAllCategories();
---

<BaseLayout
  title="Blog | Hub Digital"
  description="Artigos sobre Arquitetura, Tech e Games."
>
  <div class="pb-12">
    <div class="mb-12">
      <h1
        class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4 text-zinc-900 dark:text-brand-text"
      >
        <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-brand-primary to-brand-accent"
          >Blog</span
        >
      </h1>
      <p class="text-xl text-zinc-600 dark:text-zinc-400 max-w-2xl">
        Conteúdo aprofundado separado por domínios de conhecimento.
      </p>
    </div>

    {
      categories.map((category) => (
        <section class="mb-16">
          <div class="flex items-center gap-4 mb-8">
            <h2 class="text-3xl font-bold text-zinc-900 dark:text-brand-text">
              {category}
            </h2>
            <div class="h-px bg-zinc-200 dark:bg-brand-surface flex-grow" />
            <a
              href={`/blog/${slugifyCategory(category)}`}
              class="text-sm font-bold text-brand-accent hover:text-brand-primary transition-colors"
            >
              Ver todos →
            </a>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {posts
              .filter((post) => (post.data.category || "Geral") === category)
              .slice(0, 3)
              .map((post) => (
                <BlogCard post={post} />
              ))}
          </div>
        </section>
      ))
    }

    {
      posts.length === 0 && (
        <div class="flex flex-col items-center justify-center text-center py-24 bg-white dark:bg-brand-surface rounded-3xl border border-zinc-200 dark:border-zinc-800 shadow-sm mt-8">
          <div class="w-16 h-16 mb-4 flex items-center justify-center rounded-full bg-brand-primary/10 text-brand-primary">
            <svg
              class="w-8 h-8"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
              />
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-zinc-900 dark:text-brand-text mb-2">
            Nenhum artigo publicado
          </h3>
          <p class="text-zinc-600 dark:text-zinc-400 text-lg max-w-md">
            Minhas publicações estão no forno. Em breve teremos novidades sobre
            arquitetura, backend e muito mais.
          </p>
        </div>
      )
    }
  </div>
</BaseLayout>
