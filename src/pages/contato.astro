---
import BaseLayout from "../layouts/BaseLayout.astro";
import { resume } from "../data/resume";
---

<BaseLayout
  title="Contato | Gabriel Aquino"
  description="Entre em contato para parcerias, projetos ou apenas para tomar um café."
>
  <div class="max-w-3xl mx-auto py-12 md:py-20 text-center">
    <div
      class="inline-flex items-center justify-center p-4 bg-brand-primary/10 rounded-full mb-8"
    >
      <svg
        class="w-12 h-12 text-brand-primary"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
          d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
        ></path>
      </svg>
    </div>

    <h1
      class="text-4xl md:text-6xl font-extrabold tracking-tight text-zinc-900 dark:text-zinc-100 mb-6"
    >
      Vamos conversar?
    </h1>

    <p
      class="text-lg md:text-xl text-zinc-600 dark:text-zinc-400 mb-12 max-w-xl mx-auto leading-relaxed"
    >
      Sempre aberto a discutir novas tecnologias, arquiteturas escaláveis, ou
      oportunidades de parcerias e negócios.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={resume.socials.email}
        class="w-full sm:w-auto px-8 py-4 bg-brand-primary text-white font-bold rounded-xl hover:scale-105 hover:bg-[#ff5b5b] transition-all duration-300 shadow-xl shadow-brand-primary/30 flex items-center justify-center gap-2 text-lg"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
          ></path></svg
        >
        E-mail
      </a>

      <a
        href={resume.socials.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="w-full sm:w-auto px-8 py-4 bg-[#0A66C2] text-white font-bold rounded-xl hover:scale-105 hover:bg-[#0d7ceb] transition-all duration-300 shadow-xl shadow-[#0A66C2]/30 flex items-center justify-center gap-2 text-lg"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
          ><path
            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
          ></path></svg
        >
        LinkedIn
      </a>
    </div>

    <div class="mt-16 pt-8 border-t border-zinc-200 dark:border-zinc-800">
      <p class="text-zinc-500 dark:text-zinc-400">
        Você também pode acompanhar meus repositórios no <a
          href={resume.socials.github}
          target="_blank"
          class="text-brand-primary hover:underline font-bold">GitHub</a
        >.
      </p>
    </div>
  </div>
</BaseLayout>
